{
    "family": "burndev-widget-server",
    "taskRoleArn": "arn:aws:iam::488182246611:role/service-role/ecsTaskExecutionRole",
    "executionRoleArn": "arn:aws:iam::488182246611:role/service-role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "1024",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "containerDefinitions": [
        {
            "name": "upload-widget-server",
            "image": "488182246611.dkr.ecr.us-east-2.amazonaws.com/burnc/upload-widget-server:v6",
            "cpu": 256,
            "memory": 1024,
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 3333,
                    "protocol": "tcp",
                    "name": "port",
                    "appProtocol": "http"
                }
            ],
            "environment": [
                {
                    "name": "PORT",
                    "value": "3333"
                },
                {
                    "name": "CLOUDFLARE_BUCKET",
                    "value": "upload-widget-server"
                },
                {
                    "name": "CLOUDFLARE_PUBLIC_URL",
                    "value": "https://pub-9053b805ce90427d8c5f4046e3c1f4ea.r2.dev"
                },
                {
                    "name": "CLOUDFLARE_ACCOUNT_ID",
                    "value": "39f24742145c33b333a0b9300f1faaef"
                },
                {
                    "name": "POSTGRES_DB",
                    "value": "widget-server-db"
                },
                {
                    "name": "POSTGRES_PORT",
                    "value": "5432"
                }
            ],
            "secrets": [
                {
                    "name": "CLOUDFLARE_SECRET_ACCESS_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-2:488182246611:secret:cloudflare-credentials:CLOUDFLARE_SECRET_ACCESS_KEY::"
                },
                {
                    "name": "CLOUDFLARE_ACCESS_KEY_ID",
                    "valueFrom": "arn:aws:secretsmanager:us-east-2:488182246611:secret:cloudflare-credentials:CLOUDFLARE_ACCESS_KEY_ID::"
                },
                {
                    "name": "POSTGRES_USER",
                    "valueFrom": "arn:aws:secretsmanager:us-east-2:488182246611:secret:postgres-credentials:POSTGRES_USER::"
                },
                {
                    "name": "POSTGRES_PASSWORD",
                    "valueFrom": "arn:aws:secretsmanager:us-east-2:488182246611:secret:postgres-credentials:POSTGRES_PASSWORD::"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/burndev-widget-server",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-2",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ]
}
